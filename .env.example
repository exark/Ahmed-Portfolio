# ----------------------------------------------------------------------
# Resend — Contact form email delivery
# ----------------------------------------------------------------------
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Recipient address (where contact form messages are delivered)
CONTACT_TO_EMAIL=ali.ahmed.benhamouda@gmail.com

# Sender shown to the recipient.
# Use "onboarding@resend.dev" while testing (no domain verification needed).
# Once you verify a domain on Resend, switch to: "Ahmed <contact@yourdomain.com>"
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>
